{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "board-game-front",
  "compatibility_date": "2026-02-05", 
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "workers_dev": true,
  "preview_urls": true,
  "vars": {
    "NEXT_PUBLIC_API_URL": "https://api.walrung.com"
  }
}