{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/game/yacht/[id]",
      "regex": "^/game/yacht/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/game/yacht/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/ranking/[gameType]/[criteria]",
      "regex": "^/ranking/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgameType": "nxtPgameType",
        "nxtPcriteria": "nxtPcriteria"
      },
      "namedRegex": "^/ranking/(?<nxtPgameType>[^/]+?)/(?<nxtPcriteria>[^/]+?)(?:/)?$"
    },
    {
      "page": "/rooms/[id]",
      "regex": "^/rooms/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/rooms/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/user/status/[gameType]/[nickname]",
      "regex": "^/user/status/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgameType": "nxtPgameType",
        "nxtPnickname": "nxtPnickname"
      },
      "namedRegex": "^/user/status/(?<nxtPgameType>[^/]+?)/(?<nxtPnickname>[^/]+?)(?:/)?$"
    },
    {
      "page": "/wiki/[gameType]",
      "regex": "^/wiki/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPgameType": "nxtPgameType"
      },
      "namedRegex": "^/wiki/(?<nxtPgameType>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/auth/login",
