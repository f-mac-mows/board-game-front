      "namedRegex": "^/quest(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/rooms",
      "regex": "^/rooms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/rooms(?:/)?$"
    },
    {
      "page": "/set-nickname",
      "regex": "^/set\\-nickname(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/set\\-nickname(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
