      "routeKeys": {},
      "namedRegex": "^/cookie(?:/)?$"
    },
    {
      "page": "/icon.png",
      "regex": "^/icon\\.png(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.png(?:/)?$"
    },
    {
      "page": "/login-success",
      "regex": "^/login\\-success(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login\\-success(?:/)?$"
    },
    {
      "page": "/privacy",
