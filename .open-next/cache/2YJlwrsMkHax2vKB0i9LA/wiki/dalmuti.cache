ML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"TechArticle\\\",\\\"headline\\\":\\\"달무티 공식 가이드\\\",\\\"author\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"왈렁 온라인\\\"}}\"}}]],[\"$\",\"article\",null,{\"className\":\"max-w-3xl mx-auto animate-in fade-in slide-in-from-bottom-4 duration-700\",\"children\":[[\"$\",\"header\",null,{\"className\":\"mb-12 border-b border-slate-900 pb-8\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-blue-500 text-[10px] font-black tracking-[0.4em] uppercase mb-2 block\",\"children\":\"Official Wiki\"}],[\"$\",\"h1\",null,{\"className\":\"text-4xl md:text-5xl font-black text-white italic tracking-tighter uppercase\",\"children\":\"달무티\"}]]}],[\"$\",\"section\",null,{\"className\":\"prose prose-invert prose-slate max-w-none prose-headings:italic\",\"children\":[\"$\",\"div\",null,{\"className\":\"md-content w-full max-w-none\",\"children\":[[\"$\",\"h1\",\"h1-0\",{\"children\":\"👑 달무티 (The Great Dalmuti): 계급과 역전의 전략 가이드\"}],\"\\n\",[\"$\",\"p\",\"p-0\",{\"children\":\"달무티는 \\\"인생은 불공평합니다\\\"라는 슬로건으로 유명한 계급 역전 카드 게임입니다. 최대한 빨리 자신의 손패를 털어내어 상위 계급으로 올라가는 것이 목표이며, 계급에 따른 불평등한 세금 시스템을 실력과 운으로 극복하는 것이 핵심입니다.\"}],\"\\n\",[\"$\",\"hr\",\"hr-0\",{}],\"\\n\",[\"$\",\"h3\",\"h3-0\",{\"children\":\"1. 계급 체계 (The Hierarchy)\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":\"게임 결과에 따라 플레이어의 계급이 결정되며, 계급은 곧 권력이자 의무가 됩니다.\"}],\"\\n\",[\"$\",\"ol\",\"ol-0\",{\"children\":[\"\\n\",[\"$\",\"li\",\"li-0\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"위대한 달무티 (The Great Dalmuti)\"}],\": 1등. 왕이며 가장 먼저 카드를 낼 권리를 가집니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-1\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"소달무티 (Lesser Dalmuti)\"}],\": 2등. 귀족 계급입니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-2\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"평민 (Merchants)\"}],\": 중간 순위들입니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-3\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"소농노 (Lesser Peon)\"}],\": 뒤에서 2등입니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-4\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"위대한 농노 (Greater Peon)\"}],\": 꼴등. 카드를 섞고 나누는 모든 잔심부름을 수행합니다.\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"hr\",\"hr-1\",{}],\"\\n\",[\"$\",\"h3\",\"h3-1\",{\"children\":\"2. 카드 구성과 가치 (Card Distribution)\"}],\"\\n\",[\"$\",\"p\",\"p-2\",{\"children\":[\"카드의 숫자는 해당 카드의 \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"계급\"}],\"이자 게임 내에 존재하는 \",[\"$\",\"strong\",\"strong-1\",{\"children\":\"전체 매수\"}],\"를 의미합니다.\"]}],\"\\n\",[\"$\",\"table\",\"table-0\",{\"children\":[[\"$\",\"thead\",\"thead-0\",{\"children\":[\"$\",\"tr\",\"tr-0\",{\"children\":[[\"$\",\"th\",\"th-0\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"숫자 (계급)\"}],[\"$\",\"th\",\"th-1\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"이름\"}],[\"$\",\"th\",\"th-2\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"총 매수\"}],[\"$\",\"th\",\"th-3\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"가치\"}]]}]}],[\"$\",\"tbody\",\"tbody-0\",{\"children\":[[\"$\",\"tr\",\"tr-0\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"style\":{\"textAlign\":\"left\"},\"children\":[\"$\",\"strong\",\"strong-0\",{\"children\":\"1\"}]}],[\"$\",\"td\",\"td-1\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"달무티\"}],[\"$\",\"td\",\"td-2\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"1장\"}],[\"$\",\"td\",\"td-3\",{\"style\":{\"textAlign\":\"left\"},\"children\":[\"$\",\"strong\",\"strong-0\",{\"children\":\"최상 (Strong)\"}]}]]}],[\"$\",\"tr\",\"tr-1\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"style\":{\"textAlign\":\"left\"},\"children\":[\"$\",\"strong\",\"strong-0\",{\"children\":\"2 ~ 11\"}]}],[\"$\",\"td\",\"td-1\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"각종 직업군\"}],[\"$\",\"td\",\"td-2\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"숫자만큼 존재\"}],[\"$\",\"td\",\"td-3\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"중간\"}]]}],[\"$\",\"tr\",\"tr-2\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"