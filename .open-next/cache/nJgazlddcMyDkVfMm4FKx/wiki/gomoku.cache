,\"content\":\"https://walrung.com/og-image.webp\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:url\",\"content\":\"https://walrung.com/wiki/gomoku\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:title\",\"content\":\"오목 가이드\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:description\",\"content\":\"오목의 모든 것\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:image\",\"content\":\"https://walrung.com/og-image.webp\"}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"TechArticle\\\",\\\"headline\\\":\\\"오목 공식 가이드\\\",\\\"author\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"왈렁 온라인\\\"}}\"}}]],[\"$\",\"article\",null,{\"className\":\"max-w-3xl mx-auto animate-in fade-in slide-in-from-bottom-4 duration-700\",\"children\":[[\"$\",\"header\",null,{\"className\":\"mb-12 border-b border-slate-900 pb-8\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-blue-500 text-[10px] font-black tracking-[0.4em] uppercase mb-2 block\",\"children\":\"Official Wiki\"}],[\"$\",\"h1\",null,{\"className\":\"text-4xl md:text-5xl font-black text-white italic tracking-tighter uppercase\",\"children\":\"오목\"}]]}],[\"$\",\"section\",null,{\"className\":\"prose prose-invert prose-slate max-w-none prose-headings:italic\",\"children\":[\"$\",\"div\",null,{\"className\":\"md-content w-full max-w-none\",\"children\":[[\"$\",\"h1\",\"h1-0\",{\"children\":\"⚪️ 오목 (Gomoku): 전략과 금수 규칙 가이드\"}],\"\\n\",[\"$\",\"p\",\"p-0\",{\"children\":[\"오목은 흑과 백이 번갈아 돌을 놓아 가로, 세로, 대각선 중 어느 방향으로든 \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"자신의 돌을 5개\"}],\" 먼저 연결하는 사람이 승리하는 추상 전략 게임입니다. 왈렁 온라인에서는 공정한 승부를 위해 국제 표준인 \",[\"$\",\"strong\",\"strong-1\",{\"children\":\"렌주룰(Renju Rule)\"}],\" 기반의 금수 규칙을 제공합니다.\"]}],\"\\n\",[\"$\",\"hr\",\"hr-0\",{}],\"\\n\",[\"$\",\"h3\",\"h3-0\",{\"children\":\"1. 기본 진행 방식\"}],\"\\n\",[\"$\",\"ol\",\"ol-0\",{\"children\":[\"\\n\",[\"$\",\"li\",\"li-0\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"착수\"}],\": 흑이 먼저 바둑판의 중앙에 첫 수를 두며 시작합니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-1\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"교대\"}],\": 플레이어는 번갈아 가며 빈 교차점에 돌을 하나씩 놓습니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-2\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"승리\"}],\": 어떤 방향으로든 정확히 5개의 돌을 일렬로 먼저 만든 플레이어가 승리합니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-3\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"무승부\"}],\": 바둑판의 모든 칸이 채워졌으나 승자가 없는 경우 무승부로 처리됩니다.\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"hr\",\"hr-1\",{}],\"\\n\",[\"$\",\"h3\",\"h3-1\",{\"children\":\"2. 흑(선공)의 금수 규칙 (Forbidden Moves)\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":[\"오목은 선공인 흑이 압도적으로 유리한 게임입니다. 이를 수식으로 표현하면 흑의 승리 확률 \",[\"$\",\"span\",\"span-0\",{\"className\":\"katex\",\"children\":[[\"$\",\"span\",\"span-0\",{\"className\":\"katex-mathml\",\"children\":[\"$\",\"math\",\"math-0\",{\"xmlns\":\"http://www.w3.org/1998/Math/MathML\",\"children\":[\"$\",\"semantics\",\"semantics-0\",{\"children\":[[\"$\",\"mrow\",\"mrow-0\",{\"children\":[[\"$\",\"mi\",\"mi-0\",{\"children\":\"P\"}],[\"$\",\"mo\",\"mo-0\",{\"stretchy\":\"false\",\"children\":\"(\"}],[\"$\",\"mtext\",\"mtext-0\",{\"children\":\"Black\"}],[\"$\",\"mo\",\"mo-1\",{\"stretchy\":\"false\",\"children\":\")\"}]]}],[\"$\",\"annotation\",\"annotation-0\",{\"encoding\":\"application/x-tex\",\"children\":\"P(\\\\text{Black})\"}]]}]}]}],[\"$\",\"span\",\"span-1\",{\"className\":\"katex-html\",\"aria-hidden\":\"true\",\"children\":[\"$\",\"span\",\"span-0\",{\"className\":\"base\",\"children\":[[\"$\",\"span\",\"span-0\",{\"className\":\"strut\",\"style\":{\"height\":\"1em\",\"verticalAlign\":\"-0.25em\"}}],[\"$\",\"span\",\"span-1\",{\"className\":\"mord mathnormal\",\"style\":{\"marginRight\":\"0.13889em\"},\"children\":\"P\"}],[\"$\",\"span\",\"span-2\",{\"className\":\"mopen\",\"children\":\"(\"}],[