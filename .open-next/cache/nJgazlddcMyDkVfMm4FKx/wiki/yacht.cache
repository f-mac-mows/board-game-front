 bg-slate-950 px-6 py-12\",\"children\":[[[\"$\",\"title\",null,{\"children\":\"야추 다이스 가이드\"}],[\"$\",\"meta\",null,{\"name\":\"description\",\"content\":\"야추 다이스의 모든 것\"}],[\"$\",\"link\",null,{\"rel\":\"canonical\",\"href\":\"https://walrung.com/wiki/yacht\"}],[\"$\",\"meta\",null,{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",null,{\"property\":\"og:url\",\"content\":\"https://walrung.com/wiki/yacht\"}],[\"$\",\"meta\",null,{\"property\":\"og:title\",\"content\":\"야추 다이스 가이드\"}],[\"$\",\"meta\",null,{\"property\":\"og:description\",\"content\":\"야추 다이스의 모든 것\"}],[\"$\",\"meta\",null,{\"property\":\"og:image\",\"content\":\"https://walrung.com/og-image.webp\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:url\",\"content\":\"https://walrung.com/wiki/yacht\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:title\",\"content\":\"야추 다이스 가이드\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:description\",\"content\":\"야추 다이스의 모든 것\"}],[\"$\",\"meta\",null,{\"name\":\"twitter:image\",\"content\":\"https://walrung.com/og-image.webp\"}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"TechArticle\\\",\\\"headline\\\":\\\"야추 다이스 공식 가이드\\\",\\\"author\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"왈렁 온라인\\\"}}\"}}]],[\"$\",\"article\",null,{\"className\":\"max-w-3xl mx-auto animate-in fade-in slide-in-from-bottom-4 duration-700\",\"children\":[[\"$\",\"header\",null,{\"className\":\"mb-12 border-b border-slate-900 pb-8\",\"children\":[[\"$\",\"span\",null,{\"className\":\"text-blue-500 text-[10px] font-black tracking-[0.4em] uppercase mb-2 block\",\"children\":\"Official Wiki\"}],[\"$\",\"h1\",null,{\"className\":\"text-4xl md:text-5xl font-black text-white italic tracking-tighter uppercase\",\"children\":\"야추 다이스\"}]]}],[\"$\",\"section\",null,{\"className\":\"prose prose-invert prose-slate max-w-none prose-headings:italic\",\"children\":[\"$\",\"div\",null,{\"className\":\"md-content w-full max-w-none\",\"children\":[[\"$\",\"h1\",\"h1-0\",{\"children\":\"🎲 야추 다이스 (Yacht Dice) 완전 정복 가이드\"}],\"\\n\",[\"$\",\"p\",\"p-0\",{\"children\":\"야추 다이스는 5개의 주사위를 사용하여 정해진 조합(족보)을 완성하고, 최종 점수가 상대보다 높으면 승리하는 전략적 주사위 게임입니다. 운과 판단력이 동시에 필요한 게임의 규칙을 상세히 알아봅시다.\"}],\"\\n\",[\"$\",\"hr\",\"hr-0\",{}],\"\\n\",[\"$\",\"h3\",\"h3-0\",{\"children\":\"1. 게임 진행 방식\"}],\"\\n\",[\"$\",\"ol\",\"ol-0\",{\"children\":[\"\\n\",[\"$\",\"li\",\"li-0\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"주사위 굴리기\"}],\": 자신의 차례가 오면 5개의 주사위를 동시에 던집니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-1\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"고정(Keep) 및 다시 굴리기\"}],\":\",\"\\n\",[\"$\",\"ul\",\"ul-0\",{\"children\":[\"\\n\",[\"$\",\"li\",\"li-0\",{\"children\":[\"나온 주사위 중 마음에 드는 것은 그대로 두고(\",[\"$\",\"strong\",\"strong-0\",{\"children\":\"고정\"}],\"), 나머지 주사위만 선택해서 다시 굴릴 수 있습니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-1\",{\"children\":[\"다시 굴리기는 한 차례에 \",[\"$\",\"strong\",\"strong-0\",{\"children\":\"최대 2번\"}],\"까지 가능합니다. (첫 투구 포함 총 3번의 기회)\"]}],\"\\n\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"li\",\"li-2\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"점수 기록\"}],\": 3번의 기회가 끝나면(또는 중간에 만족하면) 반드시 점수판의 빈칸 중 하나를 선택해 점수를 기록해야 합니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-3\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"게임 종료\"}],\": 모든 플레이어가 점수판의 모든 칸(12칸)을 채우면 게임이 종료되며, \",[\"$\",\"strong\",\"strong-1\",{\"children\":\"최종 합계 점수가 높은 사람이 승리\"}],\"합니다.\"]}],\"\\n\"]}],\"\\n\",[\"$\",\"hr\",\"hr-1\",{}],\"\\n\",[\"$\",\"h3\",\"h3-1\",{\"children\":\"2. 점수 족보 (Categories)\"}],\"\\n\",[\"$\",\"h4\",\"h4-0\",{\"children\":\"📋 상단 항목 (Upper Section)\"}],\"\\n\",[\"$\",\"p\",\"p-1\",{\"children\":\"상단 항목은 해당 숫자가 나온 주사위 눈의 합을 기록합니다.\"}],\"\\n\",[\"$\",\"table\",\"table-0\",{\"children\":[[\"$\",\"thead\",\"thead-0\",{\"children\":[\"$\",\"tr\",\"tr-0\",