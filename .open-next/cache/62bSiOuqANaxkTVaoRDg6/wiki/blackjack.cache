en\":[[\"$\",\"td\",\"td-0\",{\"style\":{\"textAlign\":\"left\"},\"children\":[\"$\",\"strong\",\"strong-0\",{\"children\":\"J, Q, K\"}]}],[\"$\",\"td\",\"td-1\",{\"style\":{\"textAlign\":\"left\"},\"children\":[\"$\",\"strong\",\"strong-0\",{\"children\":\"10점\"}]}],[\"$\",\"td\",\"td-2\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"그림 카드는 모두 10으로 취급\"}]]}],[\"$\",\"tr\",\"tr-2\",{\"children\":[[\"$\",\"td\",\"td-0\",{\"style\":{\"textAlign\":\"left\"},\"children\":[\"$\",\"strong\",\"strong-0\",{\"children\":\"A (Ace)\"}]}],[\"$\",\"td\",\"td-1\",{\"style\":{\"textAlign\":\"left\"},\"children\":[\"$\",\"strong\",\"strong-0\",{\"children\":\"1 또는 11\"}]}],[\"$\",\"td\",\"td-2\",{\"style\":{\"textAlign\":\"left\"},\"children\":\"자신에게 유리한 쪽으로 선택 가능\"}]]}]]}]]}],\"\\n\",[\"$\",\"hr\",\"hr-1\",{}],\"\\n\",[\"$\",\"h3\",\"h3-1\",{\"children\":\"2. 게임 용어 및 옵션\"}],\"\\n\",[\"$\",\"p\",\"p-2\",{\"children\":\"자신의 차례에 선택할 수 있는 행동들입니다.\"}],\"\\n\",[\"$\",\"ul\",\"ul-0\",{\"children\":[\"\\n\",[\"$\",\"li\",\"li-0\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Hit (히트)\"}],\": 카드를 한 장 더 받습니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-1\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Stay (스테이)\"}],\": 카드를 더 받지 않고 현재 점수로 딜러와 대결합니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-2\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Bust (버스트)\"}],\": 카드 합이 21을 초과하는 경우입니다. 이 경우 딜러의 점수와 상관없이 \",[\"$\",\"strong\",\"strong-1\",{\"children\":\"즉시 패배\"}],\"합니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-3\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Blackjack (블랙잭)\"}],\": 처음 받은 두 장이 A와 10(또는 J, Q, K)으로 합이 정확히 21인 경우입니다. 일반 승리보다 높은 배당(보통 1.5배)을 받습니다.\"]}],\"\\n\",[\"$\",\"li\",\"li-4\",{\"children\":[[\"$\",\"strong\",\"strong-0\",{\"children\":\"Push (푸시)\"}],\": 딜러와 플레이어의 점수가 같은 경우로, 베팅 금액을 돌려받습니다.\"]}],\"\\n\"]}],\"\\n\",\"$L14\",\"\\n\",\"$L15\",\"\\n\",\"$L16\",\"\\n\",\"$L17\",\"\\n\",\"$L18\",\"\\n\",\"$L19\",\"\\n\",\"$L1a\",\"\\n\",\"$L1b\",